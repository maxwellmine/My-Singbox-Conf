        "🇺🇸 美国"
      ]
    },
    {
      "type": "selector",
      "tag": "AI",
      "interrupt_exist_connections": true,
      "outbounds": [
        "节点选择",
        "🇭🇰 香港",
        "🇨🇳 台湾",
        "🇰🇷 韩国",
        "🇸🇬 新加坡",
        "🇯🇵 日本",
        "🇺🇸 美国"
      ]
    },
    {
      "type": "selector",
      "tag": "国外分流",
      "interrupt_exist_connections": true,
      "outbounds": [
        "节点选择",
        "全球直连"
      ]
    },    
    {
      "type": "selector",
      "tag": "节点选择",
      "interrupt_exist_connections": true,
      "outbounds": [
        "🇭🇰 香港",
        "🇸🇬 新加坡",
        "🇨🇳 台湾",
        "🇯🇵 日本",
        "🇰🇷 韩国",
        "🇺🇸 美国"
      ]
    },
    {
      "type": "selector",
      "tag": "全部节点",
      "interrupt_exist_connections": true,
      "outbounds": []
    },    
    {
      "type": "urltest",
      "tag": "🇭🇰 香港",
      "interrupt_exist_connections": true,
      "outbounds": [],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "10m",
      "idle_timeout": "15m",
      "tolerance": 10
    },
    {
      "type": "urltest",
      "tag": "🇨🇳 台湾",
      "interrupt_exist_connections": true,
      "outbounds": [],
      "url": "https://www.gstatic.com/generate_204",
