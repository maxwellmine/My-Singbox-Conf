      "tolerance": 10
    },
    {
      "type": "direct",
      "tag": "全球直连"
    },
    {
      "type": "selector",
      "tag": "GLOBAL",
      "interrupt_exist_connections": true,
      "outbounds": [
        "节点选择",
        "全球直连",
        "国外分流"
      ]
    }
  ],
  "route": {
    "rules": [
    {"action": "sniff", "inbound": "tun-in"},
    {"action": "hijack-dns", "protocol": "dns"},
    {"action": "reject", "protocol": "quic"},
    {"action": "route", "clash_mode": "direct", "outbound": "全球直连"},
    {"action": "route", "clash_mode": "global", "outbound": "GLOBAL"},
    {"action": "route", "ip_is_private": true, "outbound": "全球直连"},
    {"action": "route", "geosite": ["openai", "anthropic", "google-gemini"], "outbound": "AI"},
    {"action": "route", "geosite": "telegram", "geoip": "telegram", "outbound": "Telegram"},
    {"action": "route", "geosite": "apple", "outbound": "全球直连"},
    {"action": "route", "geosite": "geolocation-!cn", "geoip": "geolocation-!cn", "outbound": "国外分流"}
  ],
    "auto_detect_interface": true,
    "final": "全球直连"
  },
  "dns": {
    "servers": [
    {"tag": "Local-DNS", "address": "tls://223.5.5.5:853", "detour": "全球直连"},
    {"tag": "Local-DNS-Resolver", "address": "udp://223.5.5.5:53", "detour": "全球直连"},
    {"tag": "Remote-DNS", "address": "tls://8.8.8.8:853", "detour": "节点选择"},
    {"tag": "Remote-DNS-Resolver", "address": "udp://8.8.8.8:53", "detour": "节点选择"}
  ],
  "rules": [
    {"action": "route", "server": "Local-DNS", "outbound": "any"},
    {"action": "route", "clash_mode": "direct", "server": "Local-DNS"},
    {"action": "route", "clash_mode": "global", "server": "Remote-DNS"},
    {"action": "route", "geosite": "geolocation-!cn", "server": "Remote-DNS"}
  ],
    "disable_cache": false,
    "disable_expire": false,
    "independent_cache": false,
    "final": "Local-DNS-Resolver"
  },
  "log": {
    "disabled": false,
    "level": "info",
    "output": "sing-box.log",
    "timestamp": false
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:20123",
      "external_ui": "ui",
      "external_ui_download_url": "https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip",
      "external_ui_download_detour": "全球直连",
      "secret": "110",
      "default_mode": "rule",
      "access_control_allow_origin": ["http://127.0.0.1:20123"],
      "access_control_allow_private_network": false
    },
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "",
      "store_fakeip": false,
      "rdrc_timeout": "7d"
    }
  },  
  "endpoints": []
}
